# Analytics & verification placeholders
# Copy to .env.local and fill before enabling AnalyticsPlaceholders.enableInProduction

VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
VITE_GTM_CONTAINER_ID=GTM-XXXXXXX
VITE_META_PIXEL_ID=000000000000000
VITE_GOOGLE_ADS_ID=AW-XXXXXXXXX
VITE_GOOGLE_ADS_CONVERSION_LABEL=XXXXXXXXXXXXXXXXXX
# Google Search Console (HTML tag method):
# 1. https://search.google.com/search-console → Add property → URL prefix: https://capillaaesthetic.com
# 2. Choose "HTML tag" verification → copy ONLY the content value (not the full meta tag)
# 3. Paste below, redeploy Vercel, then click Verify in Search Console
# 4. Submit sitemap: https://capillaaesthetic.com/sitemap.xml
VITE_SEARCH_CONSOLE_VERIFICATION=
VITE_SITE_URL=https://capillaaesthetic.com
VITE_ENABLE_ANALYTICS=false
